# ══════════════════════════════════════════════════════════════════════════════
# .env.example — copy to .env and fill in your values
#
# Spring Boot auto-loads this file via spring-dotenv (me.paulschwarz:spring-dotenv).
# All variables here are available as ${VAR_NAME} in application.yml.
#
# NEVER commit .env to version control (it is already in .gitignore)
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/ibtrader
DB_USERNAME=ibtrader
DB_PASSWORD=change_me_in_production

# ── Interactive Brokers ───────────────────────────────────────────────────────
IB_ENABLED=true                       # Set to false to disable IB Gateway connection
IB_HOST=127.0.0.1
IB_PORT=4002                          # 4002 = paper gateway; 4001 = live gateway
IB_CLIENT_ID=1
IB_PAPER_TRADING=true                 # MUST be false for live trading (requires explicit intent)
IB_ACCOUNT_ID=DU1234567               # Your IB account number (e.g. DU123456 for paper)

# ── Strategy Thresholds ───────────────────────────────────────────────────────
STRATEGY_BUY_NLV=25000.00            # Buy signal when portfolio NLV drops below this
STRATEGY_SELL_NLV=35000.00           # Sell signal when portfolio NLV rises above this
STRATEGY_FIXED_AMOUNT=1000.00        # Fixed USD amount per asset for FIXED_AMOUNT mode

# ── Server & Environment ──────────────────────────────────────────────────────
SERVER_PORT=8080
MANAGEMENT_PORT=8081
APP_ENV=local

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_DIR=logs
